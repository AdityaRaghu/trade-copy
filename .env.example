# Zerodha Trade Copier – Mirror Mode Setup

# Copy this file: cp .env.example .env
# Then fill in your actual API keys below.


# — Leader (your friend’s Kite Connect app) —
LEADER_KITE_API_KEY=your_friends_api_key
LEADER_KITE_API_SECRET=your_friends_api_secret
LEADER_KITE_REDIRECT_URL=http://127.0.0.1:8787/auth/zerodha/callback


# — Follower (your Kite Connect app) —
FOLLOWER_LABEL=Follower
FOLLOWER_KITE_API_KEY=your_api_key
FOLLOWER_KITE_API_SECRET=your_api_secret
FOLLOWER_KITE_REDIRECT_URL=http://127.0.0.1:8787/auth/zerodha/callback
FOLLOWER_LOT_SIZE=65
FOLLOWER_MAX_LOTS=1
FOLLOWER_MAX_QUANTITY_PER_ORDER=65
FOLLOWER_MAX_PRICE_DEVIATION_PERCENT=1.0


# — Safety —
# Keep this TRUE until you have tested thoroughly!
DRY_RUN=true


# — Quantity —
# 1 = same quantity as friend, 0.5 = half, 2 = double
# If your friend sells 8 lots and you want 8 lots, keep this 1
FOLLOWER_QUANTITY_MULTIPLIER=1

# Hard cap: max lots per mirrored order (0 = no cap)
# e.g. set to 10 so a typo by your friend doesn't place 100 lots for you
MAX_QUANTITY_PER_ORDER=10


# — Allowed Instruments —
# For option selling on NSE F&O, you need NFO
ALLOWED_EXCHANGES=NSE,NFO

# MIS = intraday, NRML = carry overnight/positional
ALLOWED_PRODUCTS=MIS,NRML

# regular = normal orders, amo = after-market orders
ALLOWED_VARIETIES=regular,amo

# MARKET, LIMIT, SL (stop-loss limit), SL-M (stop-loss market)
ALLOWED_ORDER_TYPES=MARKET,LIMIT,SL,SL-M


# — Replication —
# Copy cancellations (important for option selling – if friend exits, you exit)
REPLICATE_CANCELLATIONS=true

# Copy order modifications (if friend changes price/qty)
REPLICATE_MODIFICATIONS=true


# — Server —
HOST=127.0.0.1
PORT=8787